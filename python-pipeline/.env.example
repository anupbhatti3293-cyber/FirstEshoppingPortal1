# ─── LuxeHaven AI Pipeline — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Supabase Database ────────────────────────────────────────────────────────
# Same connection string as Next.js app SUPABASE_DB_POOLER_URL
# Find at: Supabase Dashboard → Project Settings → Database → Connection pooling
SUPABASE_DB_POOLER_URL=postgres://postgres.your-project:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Same key as Next.js app GEMINI_API_KEY
# Get at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── CJ Dropshipping API ──────────────────────────────────────────────────────
# Get at: https://developers.cjdropshipping.com
CJ_API_KEY=your-cj-api-key-here
CJ_EMAIL=your-cj-account-email@example.com

# ─── Kalodata API ─────────────────────────────────────────────────────────────
# Paid subscription required: https://www.kalodata.com
# Leave empty to use mock data
KALODATA_API_KEY=your-kalodata-api-key-here

# ─── Pipeline Configuration ────────────────────────────────────────────────────
# Set MOCK_MODE=true while developing (no real API calls)
MOCK_MODE=true

# Number of products to fetch per source platform
PIPELINE_TOP_N_FETCH=25

# Number of products to stage after filtering
PIPELINE_TOP_N_FINAL=10

# Hard filter: minimum product rating (0-5)
MIN_RATING=4.0

# Hard filter: price range in USD
PRICE_MIN_USD=10.0
PRICE_MAX_USD=200.0

# Database tenant ID (always 1 for LuxeHaven single-tenant)
TENANT_ID=1

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log
