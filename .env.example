# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# JWT Secrets — REQUIRED. Generate with: openssl rand -base64 64
# App will refuse to start if either is missing.
JWT_SECRET=generate_a_long_random_secret_min_32_chars
ADMIN_JWT_SECRET=generate_a_different_long_random_secret_min_32_chars

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://luxehaven.com

# Cloudinary — Required for image uploads
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Future Payment Gateway (Stripe)
# STRIPE_SECRET_KEY=your_stripe_secret_key_here
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Future Email Service
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# RESEND_API_KEY=your_resend_api_key_here

# Future AI Services (for StyleMate)
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Stripe (Feature 4) ───────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── Resend Email (Feature 4B) ────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=orders@luxehaven.com

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cart / Checkout Config ───────────────────────────────────────────────────
CART_RESERVATION_TTL_MINUTES=15
ABANDONED_CART_DELAY_MINUTES=60
