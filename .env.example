# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase connection pooler (required for Vercel — prevents connection exhaustion)
# Find at: Supabase Dashboard → Project Settings → Database → Connection pooling
SUPABASE_DB_POOLER_URL=postgres://postgres.your-project:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=luxehaven-jwt-super-secret-key-change-in-production-2026
ADMIN_JWT_SECRET=luxehaven-admin-jwt-super-secret-key-change-in-production-2026

# ─── Anthropic Claude API (StyleMate AI) ──────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Cloudinary (product image uploads) ──────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=placeholder
CLOUDINARY_API_KEY=placeholder
CLOUDINARY_API_SECRET=placeholder

# ─── Stripe ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51...
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend Email ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=orders@luxehaven.com

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CART_RESERVATION_TTL_MINUTES=15
ABANDONED_CART_DELAY_MINUTES=60
CRON_SECRET=luxehaven-cron-secret-change-in-production
