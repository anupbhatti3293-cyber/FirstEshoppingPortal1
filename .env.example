# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase Connection Pooler (required for production / Vercel to avoid connection exhaustion)
# Find this in: Supabase Dashboard → Project Settings → Database → Connection Pooling → Connection string (Transaction mode)
SUPABASE_DB_POOLER_URL=postgres://postgres.your-ref:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
ADMIN_JWT_SECRET=change-this-to-a-different-long-random-string-in-production

# ─── Anthropic Claude API (StyleMate AI) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Cloudinary (admin product image uploads only) ────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Stripe ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend Email ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=orders@yourdomain.com

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CART_RESERVATION_TTL_MINUTES=15
ABANDONED_CART_DELAY_MINUTES=60
CRON_SECRET=change-this-in-production
